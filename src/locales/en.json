    "faq": {
      "eyebrow": "Frequently asked questions",
      "heading": "Still have a question?",
      "items": {
        "privacy": {
          "q": "Is school data secure?",
          "a": "Yes. All data is stored encrypted and only processed with your school administration's permission. We do not sell data."
        },
        "abweeks": {
          "q": "How do A and B weeks work?",
          "a": "A two-week cycle is created for each class: one schedule for Week A, another for Week B. The system alternates them automatically."
        },
        "manual": {
          "q": "Can I edit the result manually?",
          "a": "Of course. Drag and drop a lesson — the system instantly checks for conflicts and suggests alternatives."
        },
        "emaktab": {
          "q": "How does e-maktab.uz integration work?",
          "a": "Connect once — teachers, classes, and subjects are imported automatically and kept up to date with later changes."
        },
        "ortools": {
          "q": "What is Google OR-Tools?",
          "a": "Google's open-source optimization library. We've adapted its CP-SAT solver to school-timetable logic constraints."
        },
        "freeLimits": {
          "q": "What are the free-plan limits?",
          "a": "Use up to 15 teachers, 20 subjects, and 10 classes with the core algorithm. e-maktab.uz integration starts from the Mini plan."
        },
